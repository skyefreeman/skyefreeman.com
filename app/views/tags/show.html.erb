<% content_for :title, @tag.name %>
<div class="page-content">
  <h1 class="page-content__title">Tag: <%= @tag.name %></h1>

  <% if @posts.any? %>
    <h2 class="page-content__section-title">Posts</h2>
    <ul class="post-list">
      <% @posts.each do |post| %>
        <li class="post-list__item">
          <%= link_to post.title, post_url_path(post), class: "post-list__title" %>
          <span class="post-list__date"><%= render("posts/published_date", post: post) %></span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @links.any? %>
    <h2 class="page-content__section-title">Links</h2>
    <ul class="post-list">
      <% @links.each do |link| %>
        <li class="post-list__item">
          <a href="<%= ensure_https_prefix(link.url) %>" class="post-list__title"><%= link.title.present? ? link.title : link.url %></a>
          <span class="post-list__date"><%= link.created_at.strftime("%B %d, %Y") %></span>
          <% if authenticated? %>
            <%= link_to "Edit", edit_link_path(link), class: "post-list__date" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @posts.empty? && @links.empty? %>
    <p class="post-list__empty">No content tagged with "<%= @tag.name %>" yet.</p>
  <% end %>
</div>
