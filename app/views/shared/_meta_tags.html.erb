<% if local_assigns[:description].present? %>
  <meta name="description" content="<%= description %>">
<% end %>

<% if local_assigns[:canonical_url].present? %>
  <link rel="canonical" href="<%= canonical_url %>">
<% end %>

<meta property="og:site_name" content="Skye Freeman">
<meta property="og:title" content="<%= local_assigns[:title] || "Skye Freeman" %>">
<% if local_assigns[:description].present? %>
  <meta property="og:description" content="<%= description %>">
<% end %>
<meta property="og:type" content="<%= local_assigns[:og_type] || "website" %>">
<% if local_assigns[:canonical_url].present? %>
  <meta property="og:url" content="<%= canonical_url %>">
<% end %>
<% resolved_image_url = local_assigns[:image_url].presence || asset_path("banner.jpg") %>
<meta property="og:image" content="<%= resolved_image_url %>">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= local_assigns[:title] || "Skye Freeman" %>">
<% if local_assigns[:description].present? %>
  <meta name="twitter:description" content="<%= description %>">
<% end %>
<meta name="twitter:image" content="<%= resolved_image_url %>">
