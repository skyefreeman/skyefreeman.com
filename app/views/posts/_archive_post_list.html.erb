<% if posts.empty? %>
  <p class="post-list__empty">No posts found.</p>
<% else %>
  <ul class="post-list">
    <% posts.each do |post| %>
      <li class="post-list__item">
        <%= link_to post.title, post_url_path(post), class: "post-list__title" %>
        <span class="post-list__date"><%= post_published_date_links(post.published_at) %><% if post.tags.any? %> &middot; <%= post_tag_links(post) %><% end %></span>
      </li>
    <% end %>
  </ul>
<% end %>
<%= link_to "← Back to tags", tags_path, class: "post__back" %>
