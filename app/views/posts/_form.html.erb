<%= form_with model: post do |f| %>
  <% if post.errors.any? %>
    <div class="form__errors">
      <p><%= pluralize(post.errors.count, "error") %> prevented this post from being saved:</p>
      <ul>
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form__group">
    <%= f.label :title, class: "form__label" %>
    <%= f.text_field :title, class: "form__input" %>
  </div>

  <div class="form__group">
    <%= f.label :body, class: "form__label" %>
    <%= f.rich_text_area :body %>
  </div>

  <div class="form__group">
    <%= f.label :header_attachment, class: "form__label" %>
    <%= f.file_field :header_attachment %>
  </div>

  <div class="form__group">
    <%= f.submit class: "form__submit" %>
  </div>
<% end %>
