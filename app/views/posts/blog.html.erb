<% content_for :title, "Blog" %>
<div class="page-content">
  <div class="page-content__header">
    <h1 class="page-content__title">Blog</h1>
    <% if authenticated? %>
      <%= link_to "New Post", new_post_path, class: "page-content__action" %>
    <% end %>
  </div>
  <ul class="post-list">
    <% @posts.each do |post| %>
      <li class="post-list__item">
        <%= link_to post.title, post_url_path(post), class: "post-list__title" %>
        <span class="post-list__date"><%= post.published_at ? render("published_date", post: post) : "DRAFT" %><% if post.tags.any? %> &middot; <%= post_tag_links(post) %><% end %></span>
      </li>
    <% end %>
  </ul>
</div>
