<%= form_with model: idea, id: "idea-form" do |f| %>
  <% if idea.errors.any? %>
    <div class="form__errors">
      <p><%= pluralize(idea.errors.count, "error") %> prevented this idea from being saved:</p>
      <ul>
        <% idea.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form__group">
    <%= f.label :title, class: "form__label" %>
    <%= f.text_area :title, class: "form__input" %>
  </div>

  <div class="form__group">
    <%= f.label :output_url, "Output URL", class: "form__label" %>
    <%= f.text_field :output_url, class: "form__input", placeholder: "https://..." %>
  </div>

<% end %>
