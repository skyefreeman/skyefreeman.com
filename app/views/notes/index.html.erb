<% content_for :title, "Notes" %>

<div class="page-content">
  <div class="page-content__header">
    <h1 class="page-content__title">Notes</h1>
    <% if authenticated? %>
      <%= link_to "New Note", new_note_path, class: "page-content__action" %>
    <% end %>
  </div>

  <% if @notes.any? %>
    <ul class="post-list">
      <% @notes.each do |note| %>
        <li class="post-list__item">
          <%= link_to note.title, note_path(note), class: "post-list__title" %>
          <span class="post-list__date"><%= note.updated_at.strftime("%B %d, %Y") %> at <%= note.updated_at.strftime("%l:%M %p").strip %><% if note.tags.any? %> &middot; <%= note.tags.map(&:name).join(", ") %><% end %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="post-list__empty">No notes yet.</p>
  <% end %>
</div>
