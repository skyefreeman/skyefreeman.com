<div class="page-content">
  <h1 class="page-content__title">Latest Posts</h1>
  <ul class="post-list">
    <% @posts.each do |post| %>
      <li class="post-list__item">
        <%= link_to post.title, post_url_path(post), class: "post-list__title" %>
        <span class="post-list__date"><%= post.published_at ? post.published_at.strftime("%b %d, %Y") : "DRAFT" %></span>
      </li>
    <% end %>
  </ul>
  <%= link_to "Read more on the blog", blog_path, class: "post__back" %>
</div>
